<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="AnonGee · BIM Generation"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFFFF"
        FontFamily="JetBrains Mono, Source Serif 4, Inter, Segoe UI, Calibri">

    <!--
    ═══════════════════════════════════════════════════════════════════════════
    DECLARATION ORDER — MANDATORY. XamlReader.Load() resolves {StaticResource}
    eagerly at parse time. Every key MUST be declared before any element that
    references it. Never add a new resource below a ControlTemplate that uses
    it. The required order is:

      LAYER 1 — Color primitives       (no dependencies)
      LAYER 2 — SolidColorBrush        (depends on: Colors)
      LAYER 3 — FontFamily + Doubles   (no dependencies)
      LAYER 4 — DropShadowEffect       (no dependencies)
      LAYER 5 — Base TextBlock Styles  (depends on: Brushes, Fonts)
      LAYER 6 — OnDark Style variants  (depends on: Base TextBlock Styles)
      LAYER 7 — Geometry (Icons)       (no dependencies)
      LAYER 8 — Button Styles          (depends on: Brushes, Fonts)
      LAYER 9 — Input Styles           (depends on: Brushes, Fonts, Elevations)
      LAYER 10 — Card / Border Styles  (depends on: Brushes, Elevations)
      LAYER 11 — ControlTemplates      (depends on: ALL of the above)
      LAYER 12 — Section / Layout      (depends on: ALL of the above)

    See §12.7 of AnonGee Brand Guidelines v3.0.
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <Window.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 1 — Color Primitives  (Colors.xaml v3.0)
                 ═══════════════════════════════════════════════════════════ -->

            <!-- Brand Colors -->
            <Color x:Key="ColorVividRed">#FFE02020</Color>
            <Color x:Key="ColorCharcoalBlack">#FF141414</Color>
            <Color x:Key="ColorSilverSteel">#FFC0C8D8</Color>

            <!-- Surface and Text Neutrals -->
            <Color x:Key="ColorPureWhite">#FFFFFFFF</Color>
            <Color x:Key="ColorOffWhite">#FFF4F4F6</Color>
            <Color x:Key="ColorMidGrey">#FF6B7280</Color>
            <Color x:Key="ColorLightBorder">#FFE2E4EA</Color>

            <!-- Semantic / State Colors -->
            <Color x:Key="ColorSuccessGreen">#FF16A34A</Color>
            <Color x:Key="ColorCautionAmber">#FFD97706</Color>
            <Color x:Key="ColorErrorRed">#FFDC2626</Color>
            <Color x:Key="ColorInfoBlue">#FF2563EB</Color>

            <!-- Hover and Pressed Variants -->
            <Color x:Key="ColorVividRedHover">#FFC41A1A</Color>
            <Color x:Key="ColorVividRedPressed">#FFA81515</Color>
            <Color x:Key="ColorErrorRedHover">#FFB91C1C</Color>
            <Color x:Key="ColorVividRed10">#1AE02020</Color>
            <Color x:Key="ColorOffWhiteHover">#FFE8E8EC</Color>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 2 — SolidColorBrush  (depends on: Layer 1)
                 ═══════════════════════════════════════════════════════════ -->

            <!-- Brand brushes -->
            <SolidColorBrush x:Key="BrushVividRed"      Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushCharcoalBlack" Color="{StaticResource ColorCharcoalBlack}"/>
            <SolidColorBrush x:Key="BrushSilverSteel"   Color="{StaticResource ColorSilverSteel}"/>

            <!-- Surface brushes -->
            <SolidColorBrush x:Key="BrushPureWhite"     Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushOffWhite"      Color="{StaticResource ColorOffWhite}"/>
            <SolidColorBrush x:Key="BrushMidGrey"       Color="{StaticResource ColorMidGrey}"/>
            <SolidColorBrush x:Key="BrushLightBorder"   Color="{StaticResource ColorLightBorder}"/>

            <!-- Semantic brushes -->
            <SolidColorBrush x:Key="BrushSuccessGreen"  Color="{StaticResource ColorSuccessGreen}"/>
            <SolidColorBrush x:Key="BrushCautionAmber"  Color="{StaticResource ColorCautionAmber}"/>
            <SolidColorBrush x:Key="BrushErrorRed"      Color="{StaticResource ColorErrorRed}"/>
            <SolidColorBrush x:Key="BrushInfoBlue"      Color="{StaticResource ColorInfoBlue}"/>

            <!-- Hover/Pressed brushes -->
            <SolidColorBrush x:Key="BrushVividRedHover"    Color="{StaticResource ColorVividRedHover}"/>
            <SolidColorBrush x:Key="BrushVividRedPressed"  Color="{StaticResource ColorVividRedPressed}"/>
            <SolidColorBrush x:Key="BrushErrorRedHover"    Color="{StaticResource ColorErrorRedHover}"/>
            <SolidColorBrush x:Key="BrushSecondaryHover"   Color="{StaticResource ColorVividRed10}"/>
            <SolidColorBrush x:Key="BrushGhostHover"       Color="{StaticResource ColorOffWhiteHover}"/>

            <!-- State brushes -->
            <SolidColorBrush x:Key="BrushDisabledBackground"  Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushDisabledForeground"  Color="{StaticResource ColorSilverSteel}"/>

            <!-- Button-specific role brushes -->
            <SolidColorBrush x:Key="BrushPrimaryForeground"   Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushSecondaryBackground" Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushSecondaryBorder"     Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushSecondaryForeground" Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushNeutralBackground"   Color="{StaticResource ColorOffWhite}"/>
            <SolidColorBrush x:Key="BrushNeutralForeground"   Color="{StaticResource ColorCharcoalBlack}"/>
            <SolidColorBrush x:Key="BrushNeutralBorder"       Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushDangerForeground"    Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushGhostForeground"     Color="{StaticResource ColorMidGrey}"/>

            <!-- Input-specific brushes -->
            <SolidColorBrush x:Key="BrushInputBackground"   Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushInputBorder"       Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushInputFocusBorder"  Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushInputErrorBorder"  Color="{StaticResource ColorErrorRed}"/>

            <!-- Badge brushes -->
            <SolidColorBrush x:Key="BrushSuccessBadgeBackground" Color="#DCFCE7"/>
            <SolidColorBrush x:Key="BrushSuccessBadgeText"       Color="#15803D"/>
            <SolidColorBrush x:Key="BrushWarningBadgeBackground" Color="#FEF9C3"/>
            <SolidColorBrush x:Key="BrushWarningBadgeText"       Color="#92400E"/>
            <SolidColorBrush x:Key="BrushErrorBadgeBackground"   Color="#FEE2E2"/>
            <SolidColorBrush x:Key="BrushErrorBadgeText"         Color="#991B1B"/>
            <SolidColorBrush x:Key="BrushInfoBadgeBackground"    Color="#DBEAFE"/>
            <SolidColorBrush x:Key="BrushInfoBadgeText"          Color="#1D4ED8"/>
            <SolidColorBrush x:Key="BrushBetaBadgeBackground"    Color="{StaticResource ColorCharcoalBlack}"/>
            <SolidColorBrush x:Key="BrushBetaBadgeText"          Color="{StaticResource ColorSilverSteel}"/>
            <SolidColorBrush x:Key="BrushActiveBadgeBackground"  Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushActiveBadgeText"        Color="{StaticResource ColorPureWhite}"/>

            <!-- Table brushes -->
            <SolidColorBrush x:Key="BrushTableHeaderBackground" Color="{StaticResource ColorCharcoalBlack}"/>
            <SolidColorBrush x:Key="BrushTableHeaderText"       Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushTableRowHover"         Color="#FDECEA"/>
            <SolidColorBrush x:Key="BrushTableRowSelected"      Color="#FEF2F2"/>
            <SolidColorBrush x:Key="BrushTableRowSelectedBorder" Color="{StaticResource ColorVividRed}"/>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 3 — FontFamily + Size Doubles  (Typography.xaml v3.0)
                 No dependencies — safe to declare here.
                 ═══════════════════════════════════════════════════════════ -->

            <FontFamily x:Key="FontSans">JetBrains Mono, Source Serif 4, Inter, Segoe UI, Calibri</FontFamily>
            <FontFamily x:Key="FontMono">JetBrains Mono, Consolas, Courier New</FontFamily>

            <sys:Double x:Key="FontSizeH1">21</sys:Double>
            <sys:Double x:Key="FontSizeH2">16.5</sys:Double>
            <sys:Double x:Key="FontSizeH3">12</sys:Double>
            <sys:Double x:Key="FontSizeH4">10.5</sys:Double>
            <sys:Double x:Key="FontSizeBody">10.5</sys:Double>
            <sys:Double x:Key="FontSizeSmall">9</sys:Double>
            <sys:Double x:Key="FontSizeCaption">9</sys:Double>
            <sys:Double x:Key="FontSizeCode">9</sys:Double>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 4 — DropShadowEffect  (no dependencies)
                 ═══════════════════════════════════════════════════════════ -->

            <DropShadowEffect x:Key="ElevationLevel0" Opacity="0"    BlurRadius="0"  ShadowDepth="0" Direction="270"/>
            <DropShadowEffect x:Key="ElevationLevel1" Color="#000000" Opacity="0.10" BlurRadius="3"  ShadowDepth="1" Direction="270"/>
            <DropShadowEffect x:Key="ElevationLevel2" Color="#000000" Opacity="0.14" BlurRadius="12" ShadowDepth="4" Direction="270"/>
            <DropShadowEffect x:Key="ElevationLevel3" Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="8" Direction="270"/>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 5 — Base TextBlock Styles  (depends on: Layers 2, 3)
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="TextH1" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeH1}"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="LineHeight"  Value="26"/>
                <Setter Property="Margin"      Value="0,0,0,8"/>
            </Style>

            <Style x:Key="TextH2" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeH2}"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Margin"      Value="0,0,0,4"/>
            </Style>

            <Style x:Key="TextH3" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeH3}"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
            </Style>

            <Style x:Key="TextH4" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeH4}"/>
                <Setter Property="FontWeight"  Value="Medium"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
            </Style>

            <Style x:Key="TextBody" TargetType="TextBlock">
                <Setter Property="FontFamily"   Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"     Value="{StaticResource FontSizeBody}"/>
                <Setter Property="FontWeight"   Value="Normal"/>
                <Setter Property="Foreground"   Value="{StaticResource BrushMidGrey}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="LineHeight"   Value="17"/>
            </Style>

            <Style x:Key="TextSmall" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="FontWeight"  Value="Normal"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushMidGrey}"/>
            </Style>

            <Style x:Key="TextCaption" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeCaption}"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushMidGrey}"/>
            </Style>

            <Style x:Key="TextCode" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeCode}"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushSilverSteel}"/>
                <Setter Property="Background"  Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Padding"     Value="16,12"/>
                <Setter Property="LineHeight"  Value="14"/>
            </Style>

            <Style x:Key="TextError" TargetType="TextBlock">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeCaption}"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushErrorRed}"/>
                <Setter Property="Margin"      Value="0,4,0,0"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 6 — OnDark Style Variants  (depends on: Layer 5)
                 CRITICAL: Must come BEFORE any ControlTemplate that uses them.
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="TextH2OnDark" BasedOn="{StaticResource TextH2}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushPureWhite}"/>
            </Style>

            <Style x:Key="TextH3OnDark" BasedOn="{StaticResource TextH3}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushSilverSteel}"/>
            </Style>

            <Style x:Key="TextBodyOnDark" BasedOn="{StaticResource TextBody}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushSilverSteel}"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 7 — Geometry / Icons  (Icons.xaml v3.0)
                 No dependencies — safe at any position above first use.
                 ═══════════════════════════════════════════════════════════ -->

            <Geometry x:Key="IconCheck">M0,0 L3,3 L7,-1</Geometry>
            <Geometry x:Key="IconCheckCircle">M22 11.08V12a10 10 0 1 1-5.93-9.14 M22 4L12 14.01l-3-3</Geometry>
            <Geometry x:Key="IconXCircle">M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2s10 4.477 10 10z M15 9l-6 6 M9 9l6 6</Geometry>
            <Geometry x:Key="IconAlertTriangle">M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01</Geometry>
            <Geometry x:Key="IconFolderOpen">M6 14l1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 4.63A2 2 0 0 1 18.45 19H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4l2 2h5a2 2 0 0 1 2 2v3H6z</Geometry>
            <Geometry x:Key="IconDownload">M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3</Geometry>
            <Geometry x:Key="IconChevronDown">M6 9l6 6 6-6</Geometry>
            <Geometry x:Key="IconClose">M18 6L6 18 M6 6l12 12</Geometry>
            <Geometry x:Key="IconSearch">M14 14l5.4 5.4 M10 16a6 6 0 1 0 0-12 6 6 0 0 0 0 12z</Geometry>
            <Geometry x:Key="IconSettings">M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z</Geometry>
            <Geometry x:Key="IconRefresh">M23 4v6h-6 M1 20v-6h6 M3.51 9a9 9 0 0 1 14.85-3.36L23 10 M1 14l4.64 4.36A9 9 0 0 0 20.49 15</Geometry>
            <Geometry x:Key="IconLayers">M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5</Geometry>
            <Geometry x:Key="IconZap">M13 2L3 14h9l-1 8 10-12h-9l1-8z</Geometry>
            <Geometry x:Key="IconInfo">M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M12 16v-4 M12 8h.01</Geometry>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 8 — Button Styles  (depends on: Layers 2, 3)
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="ButtonBaseStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="16,0"/>
                <Setter Property="Height"          Value="36"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"        Value="{StaticResource FontSizeBody}"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="BorderBrush"     Value="Transparent"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ButtonPrimary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushVividRed}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushPrimaryForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedPressed}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonSecondary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushSecondaryBackground}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushSecondaryForeground}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushSecondaryBorder}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushSecondaryHover}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background"  Value="{StaticResource BrushDisabledBackground}"/>
                        <Setter Property="Foreground"  Value="{StaticResource BrushDisabledForeground}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BrushDisabledBackground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonGhost" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushGhostForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushGhostHover}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 9 — Input Styles  (depends on: Layers 2, 3, 4)
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="InputTextBox" TargetType="TextBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Height"                   Value="28"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <!-- fill / content / stroke-on-top: uniform 1px border on all edges -->
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="8,0" VerticalAlignment="Center"/>
                                <Border x:Name="Stroke" CornerRadius="5"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        IsHitTestVisible="False"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="Stroke" Property="BorderBrush"     Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter TargetName="Stroke" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Background"  Value="{StaticResource BrushDisabledBackground}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputComboBox" TargetType="ComboBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Padding"                  Value="10,8"/>
                <Setter Property="Height"                   Value="36"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="RootBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <Grid>
                                        <ToggleButton x:Name="ToggleButton"
                                                      Focusable="False"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                                      ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid Background="Transparent">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0"
                                                                          Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Content="{TemplateBinding Content}"
                                                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                                        <Path Grid.Column="1"
                                                              Data="M0,0 L4,4 L8,0"
                                                              Fill="{StaticResource BrushMidGrey}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter x:Name="ContentSite"
                                                          IsHitTestVisible="False"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    </Grid>
                                </Border>
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                      >
                                    <Border MinWidth="{TemplateBinding ActualWidth}" MaxWidth="520" BorderBrush="{StaticResource BrushLightBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Background="{StaticResource BrushPureWhite}"
                                            Effect="{StaticResource ElevationLevel2}">
                                        <ScrollViewer MaxHeight="200" Margin="4" HorizontalScrollBarVisibility="Hidden">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="RootBorder" Property="BorderBrush"
                                            Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter TargetName="RootBorder" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="RootBorder" Property="Background"
                                            Value="{StaticResource BrushDisabledBackground}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 10 — Card / Border Styles  (depends on: Layers 2, 4)
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background"        Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="BorderBrush"       Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness"   Value="1"/>
                <Setter Property="CornerRadius"      Value="8"/>
                <Setter Property="Padding"           Value="16"/>
            </Style>

            <Style x:Key="CardElevated" TargetType="Border" BasedOn="{StaticResource CardBorder}">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" Opacity="0.10" BlurRadius="12"
                                          ShadowDepth="4" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SectionDivider" TargetType="Rectangle">
                <Setter Property="Height"  Value="1"/>
                <Setter Property="Fill"    Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="Margin"  Value="0,16"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 11 — ControlTemplates  (depends on: ALL layers above)
                 TextH2OnDark, TextH3OnDark, all Brushes must already exist.
                 ═══════════════════════════════════════════════════════════ -->

            <ControlTemplate x:Key="AnonGeeWindowTemplate" TargetType="Window">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BrushCharcoalBlack}"
                            Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{TemplateBinding Title}"
                                       Style="{StaticResource TextH2OnDark}"/>
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource BrushSilverSteel}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Rectangle DockPanel.Dock="Top"
                               Height="3"
                               Fill="{StaticResource BrushVividRed}"/>
                    <Border DockPanel.Dock="Bottom"
                            Background="{StaticResource BrushOffWhite}"
                            BorderBrush="{StaticResource BrushLightBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="16,10"
                            Height="52">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ScrollViewer Padding="20"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ContentPresenter/>
                    </ScrollViewer>
                </DockPanel>
            </ControlTemplate>

            <ControlTemplate x:Key="AnonGeeDialogTemplate" TargetType="Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushCharcoalBlack}"
                            Padding="20,14">
                        <TextBlock Text="{TemplateBinding Title}"
                                   Style="{StaticResource TextH2OnDark}"/>
                    </Border>
                    <Rectangle Grid.Row="1"
                               Height="3"
                               Fill="{StaticResource BrushVividRed}"/>
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,18,20,20">
                        <ContentPresenter/>
                    </ScrollViewer>
                    <Border Grid.Row="3"
                            Background="{StaticResource BrushOffWhite}"
                            BorderBrush="{StaticResource BrushLightBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="20,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="CancelButton"
                                    Style="{StaticResource ButtonGhost}"
                                    Content="Cancel"
                                    Margin="0,0,8,0"
                                    IsCancel="True"/>
                            <Button x:Name="ConfirmButton"
                                    Style="{StaticResource ButtonPrimary}"
                                    Content="Confirm"
                                    IsDefault="True"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ControlTemplate>

            <ControlTemplate x:Key="DockablePanelTemplate" TargetType="HeaderedContentControl">
                <Border MinWidth="240" MaxWidth="360" Padding="0"
                        Background="{StaticResource BrushPureWhite}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BrushCharcoalBlack}"
                                Padding="12,10">
                            <TextBlock Text="{TemplateBinding Header}"
                                       Style="{StaticResource TextH3OnDark}"/>
                        </Border>
                        <Rectangle DockPanel.Dock="Top"
                                   Height="2"
                                   Fill="{StaticResource BrushVividRed}"/>
                        <ScrollViewer Padding="12,14"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentPresenter/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </ControlTemplate>

            <!-- ═══════════════════════════════════════════════════════════
                 LAYER 12 — Section / Layout Styles  (depends on: ALL above)
                 ═══════════════════════════════════════════════════════════ -->

            <Style x:Key="SectionGroup" TargetType="GroupBox">
                <Setter Property="BorderBrush"     Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background"      Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="Padding"         Value="14,12"/>
                <Setter Property="Margin"          Value="0,0,0,16"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Style="{StaticResource TextH3}"
                                               Margin="2,0,0,8"/>
                                    <ContentPresenter/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         WINDOW LAYOUT
         Header → Red Accent Rule → Scrolling Content → Footer Action Bar
         ═══════════════════════════════════════════════════════════════════ -->

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BrushCharcoalBlack}"
                Padding="20,14">
            <TextBlock Text="AnonGee · BIM Generation"
                       Style="{StaticResource TextH2OnDark}"/>
        </Border>

        <!-- Red Accent Rule -->
        <Border DockPanel.Dock="Top"
                Height="3"
                Background="{StaticResource BrushVividRed}"/>

        <!-- Footer Action Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BrushOffWhite}"
                BorderBrush="{StaticResource BrushLightBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ButtonCancel"
                        Content="Cancel"
                        Style="{StaticResource ButtonGhost}"
                        Margin="0,0,16,0"
                        IsCancel="True"/>
                <Button x:Name="ButtonGenerate"
                        Content="Generate Structures"
                        Style="{StaticResource ButtonPrimary}"
                        IsDefault="True"/>
            </StackPanel>
        </Border>

        <!-- Scrolling Content -->
        <ScrollViewer Padding="20,18,20,20"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Section: File Input -->
                <GroupBox Header="Data Ingestion Payload"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <TextBlock Text="Requires standard FRAME outputs format (.inp / .txt)"
                                   Style="{StaticResource TextCaption}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputFilePathBox"
                                     Grid.Column="0"
                                     Style="{StaticResource InputTextBox}"
                                     Margin="0,0,8,0"
                                     IsReadOnly="True"/>
                            <Button x:Name="ButtonBrowsePath"
                                    Grid.Column="1"
                                    Content="Browse..."
                                    Style="{StaticResource ButtonSecondary}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Section: Level Naming -->
                <GroupBox Header="Level Sequence Naming Definitions"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <TextBlock Text="Define output parameters for consecutive level generations"
                                   Style="{StaticResource TextCaption}"
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Prefix"
                                           Style="{StaticResource TextCaption}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="LevelPrefixInput"
                                         Style="{StaticResource InputTextBox}"
                                         Text="00"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Base Ordinal"
                                           Style="{StaticResource TextCaption}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="LevelBaseInput"
                                         Style="{StaticResource InputTextBox}"
                                         Text="0TH"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Suffix"
                                           Style="{StaticResource TextCaption}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="LevelSuffixInput"
                                         Style="{StaticResource InputTextBox}"
                                         Text="LVL."/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Separator"
                                           Style="{StaticResource TextCaption}"
                                           Margin="0,0,0,4"/>
                                <TextBox x:Name="LevelSeparatorInput"
                                         Style="{StaticResource InputTextBox}"
                                         Text=" "/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="TextLevelPreview"
                                   Text="Preview generation mapping waiting..."
                                   Style="{StaticResource TextSmall}"
                                   Foreground="{StaticResource BrushInfoBlue}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Section: Family Selection -->
                <GroupBox Header="Entity Deployment Families"
                          Style="{StaticResource SectionGroup}"
                          Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Structural Column Framing Profile"
                                       Style="{StaticResource TextH4}"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ComboStructuralColumns"
                                      Style="{StaticResource InputComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Structural Beam Framing"
                                       Style="{StaticResource TextH4}"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ComboStructuralBeams"
                                      Style="{StaticResource InputComboBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Concrete Floor / Slab Type"
                                       Style="{StaticResource TextH4}"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ComboFloorTypes"
                                      Style="{StaticResource InputComboBox}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</Window>
