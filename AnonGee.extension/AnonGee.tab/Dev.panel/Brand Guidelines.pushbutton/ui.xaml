<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="AnonGee Brand Guidelines"
        Height="740" Width="640"
        MinHeight="520" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>

            <!-- ═══ AnonGee BIM Tools — Inlined Theme v3.2 (canonical showcase) ═══ -->

            <!-- ── Colors ── -->
            <Color x:Key="ColorVividRed">#FFE02020</Color>
            <Color x:Key="ColorCharcoalBlack">#FF141414</Color>
            <Color x:Key="ColorSilverSteel">#FFC0C8D8</Color>
            <Color x:Key="ColorPureWhite">#FFFFFFFF</Color>
            <Color x:Key="ColorOffWhite">#FFF4F4F6</Color>
            <Color x:Key="ColorMidGrey">#FF6B7280</Color>
            <Color x:Key="ColorLightBorder">#FFE2E4EA</Color>
            <Color x:Key="ColorSuccessGreen">#FF16A34A</Color>
            <Color x:Key="ColorCautionAmber">#FFD97706</Color>
            <Color x:Key="ColorErrorRed">#FFDC2626</Color>
            <Color x:Key="ColorInfoBlue">#FF2563EB</Color>
            <Color x:Key="ColorVividRedHover">#FFC41A1A</Color>
            <Color x:Key="ColorVividRedPressed">#FFA81515</Color>
            <Color x:Key="ColorErrorRedHover">#FFB91C1C</Color>
            <Color x:Key="ColorErrorRedPressed">#FF991B1B</Color>
            <Color x:Key="ColorVividRed10">#1AE02020</Color>
            <Color x:Key="ColorOffWhiteHover">#FFE8E8EC</Color>

            <SolidColorBrush x:Key="BrushVividRed"            Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushCharcoalBlack"       Color="{StaticResource ColorCharcoalBlack}"/>
            <SolidColorBrush x:Key="BrushSilverSteel"         Color="{StaticResource ColorSilverSteel}"/>
            <SolidColorBrush x:Key="BrushPureWhite"           Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushOffWhite"            Color="{StaticResource ColorOffWhite}"/>
            <SolidColorBrush x:Key="BrushMidGrey"             Color="{StaticResource ColorMidGrey}"/>
            <SolidColorBrush x:Key="BrushLightBorder"         Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushSuccessGreen"        Color="{StaticResource ColorSuccessGreen}"/>
            <SolidColorBrush x:Key="BrushCautionAmber"        Color="{StaticResource ColorCautionAmber}"/>
            <SolidColorBrush x:Key="BrushErrorRed"            Color="{StaticResource ColorErrorRed}"/>
            <SolidColorBrush x:Key="BrushInfoBlue"            Color="{StaticResource ColorInfoBlue}"/>
            <SolidColorBrush x:Key="BrushVividRedHover"       Color="{StaticResource ColorVividRedHover}"/>
            <SolidColorBrush x:Key="BrushVividRedPressed"     Color="{StaticResource ColorVividRedPressed}"/>
            <SolidColorBrush x:Key="BrushErrorRedHover"       Color="{StaticResource ColorErrorRedHover}"/>
            <SolidColorBrush x:Key="BrushErrorRedPressed"     Color="{StaticResource ColorErrorRedPressed}"/>
            <SolidColorBrush x:Key="BrushSecondaryHover"      Color="{StaticResource ColorVividRed10}"/>
            <SolidColorBrush x:Key="BrushGhostHover"          Color="{StaticResource ColorOffWhiteHover}"/>
            <SolidColorBrush x:Key="BrushDisabledBackground"  Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushDisabledForeground"  Color="{StaticResource ColorSilverSteel}"/>
            <SolidColorBrush x:Key="BrushPrimaryForeground"   Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushSecondaryBackground" Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushSecondaryBorder"     Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushSecondaryForeground" Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushGhostForeground"     Color="{StaticResource ColorMidGrey}"/>
            <SolidColorBrush x:Key="BrushInputBackground"     Color="{StaticResource ColorPureWhite}"/>
            <SolidColorBrush x:Key="BrushInputBorder"         Color="{StaticResource ColorLightBorder}"/>
            <SolidColorBrush x:Key="BrushInputFocusBorder"    Color="{StaticResource ColorVividRed}"/>
            <SolidColorBrush x:Key="BrushTableRowHover"          Color="#FDECEA"/>
            <SolidColorBrush x:Key="BrushTableRowSelected"       Color="#FEF2F2"/>
            <SolidColorBrush x:Key="BrushSuccessBadgeBackground" Color="#DCFCE7"/>
            <SolidColorBrush x:Key="BrushSuccessBadgeText"       Color="#15803D"/>
            <SolidColorBrush x:Key="BrushWarningBadgeBackground" Color="#FEF9C3"/>
            <SolidColorBrush x:Key="BrushWarningBadgeText"       Color="#92400E"/>
            <SolidColorBrush x:Key="BrushErrorBadgeBackground"   Color="#FEE2E2"/>
            <SolidColorBrush x:Key="BrushErrorBadgeText"         Color="#991B1B"/>
            <SolidColorBrush x:Key="BrushInfoBadgeBackground"    Color="#DBEAFE"/>
            <SolidColorBrush x:Key="BrushInfoBadgeText"          Color="#1D4ED8"/>

            <!-- ── Elevation ── -->
            <DropShadowEffect x:Key="ElevationLevel2"
                              Color="#000000" Opacity="0.14" BlurRadius="12" ShadowDepth="4" Direction="270"/>

            <!-- ── Typography ── -->
            <FontFamily x:Key="FontSans">JetBrains Mono, Source Serif 4, Inter, Segoe UI, Calibri</FontFamily>
            <FontFamily x:Key="FontMono">JetBrains Mono, Consolas, Courier New</FontFamily>
            <sys:Double x:Key="FontSizeH1">21</sys:Double>
            <sys:Double x:Key="FontSizeH2">16.5</sys:Double>
            <sys:Double x:Key="FontSizeH3">11</sys:Double>
            <sys:Double x:Key="FontSizeBody">10.5</sys:Double>
            <sys:Double x:Key="FontSizeSmall">9.5</sys:Double>
            <sys:Double x:Key="FontSizeCaption">8.5</sys:Double>

            <Style x:Key="TextH1" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeH1}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
            </Style>
            <Style x:Key="TextH2" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeH2}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
            </Style>
            <Style x:Key="TextH2OnDark" BasedOn="{StaticResource TextH2}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushPureWhite}"/>
            </Style>
            <Style x:Key="TextH3" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeH3}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource BrushVividRed}"/>
            </Style>
            <Style x:Key="TextBody" TargetType="TextBlock">
                <Setter Property="FontFamily"   Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"     Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"   Value="{StaticResource BrushMidGrey}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
            <Style x:Key="TextLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
            </Style>
            <Style x:Key="TextCaption" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeCaption}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushMidGrey}"/>
            </Style>
            <Style x:Key="TextSwatchHex" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                <Setter Property="Foreground" Value="{StaticResource BrushSilverSteel}"/>
            </Style>

            <!-- ── Buttons ── -->
            <Style x:Key="ButtonBaseStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="12,0"/>
                <Setter Property="Height"          Value="28"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"        Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="BorderBrush"     Value="Transparent"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ButtonPrimary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushVividRed}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushPrimaryForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedPressed}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonSecondary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushSecondaryBackground}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushSecondaryForeground}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushSecondaryBorder}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushSecondaryHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonDanger" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushErrorRed}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushPrimaryForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushErrorRedHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushErrorRedPressed}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonGhost" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushGhostForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushGhostHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── TextBox ── -->
            <Style x:Key="InputTextBox" TargetType="TextBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Height"                   Value="28"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <!-- Fill / content / stroke-on-top so the 1px border
                                 is uniform on all edges (the scroller can't ride
                                 over it). -->
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="8,0" VerticalAlignment="Center"/>
                                <Border x:Name="Stroke" CornerRadius="5"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        IsHitTestVisible="False"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="Stroke" Property="BorderBrush"     Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter TargetName="Stroke" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ComboBox ── -->
            <Style x:Key="InputComboBox" TargetType="ComboBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"          Value="1"/>
                <Setter Property="Padding"                  Value="10,6"/>
                <Setter Property="Height"                   Value="28"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="RootBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <Grid>
                                        <ToggleButton x:Name="ToggleButton" Focusable="False"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                                      ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid Background="Transparent">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Content="{TemplateBinding Content}"/>
                                                        <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                              Fill="{StaticResource BrushMidGrey}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"/>
                                    </Grid>
                                </Border>
                                <Popup x:Name="Popup" Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False"
                                       PopupAnimation="Slide"
                                      >
                                    <Border MinWidth="{TemplateBinding ActualWidth}" MaxWidth="520" BorderBrush="{StaticResource BrushLightBorder}"
                                            BorderThickness="1" CornerRadius="6"
                                            Background="{StaticResource BrushPureWhite}"
                                            Effect="{StaticResource ElevationLevel2}">
                                        <ScrollViewer MaxHeight="200" Margin="4" HorizontalScrollBarVisibility="Hidden">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="RootBorder" Property="BorderBrush"     Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter TargetName="RootBorder" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="FontFamily"  Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"  Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="Padding"     Value="10,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowSelected}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── CheckBox (implicit) ── -->
            <Style TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="MinHeight"  Value="22"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckBoxBorder" Grid.Column="0"
                                        Width="16" Height="16" CornerRadius="3"
                                        BorderBrush="{StaticResource BrushLightBorder}"
                                        BorderThickness="1"
                                        Background="{StaticResource BrushPureWhite}"
                                        VerticalAlignment="Center">
                                    <Viewbox x:Name="CheckMark" Margin="3" Visibility="Collapsed">
                                        <Path Data="M0,3.5 L3.5,7 L9,0"
                                              Stroke="{StaticResource BrushPureWhite}"
                                              StrokeThickness="1.8"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"/>
                                    </Viewbox>
                                </Border>
                                <ContentPresenter Grid.Column="1" Margin="7,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark"      Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="CheckBoxBorder" Property="Background"  Value="{StaticResource BrushVividRed}"/>
                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource BrushVividRed}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource BrushVividRed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── RadioButton (implicit) — §9.4 ── -->
            <Style TargetType="RadioButton">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center">
                                    <Ellipse x:Name="Ring" Stroke="{StaticResource BrushLightBorder}"
                                             StrokeThickness="1.4" Fill="{StaticResource BrushPureWhite}"/>
                                    <Ellipse x:Name="Dot" Width="8" Height="8"
                                             Fill="{StaticResource BrushVividRed}" Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1" Margin="7,0,0,0"
                                                  VerticalAlignment="Center" RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Dot"  Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Ring" Property="Stroke"     Value="{StaticResource BrushVividRed}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource BrushVividRed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Toggle Switch (Brand Guidelines §9.9) ── -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="MinHeight"  Value="24"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                <Border x:Name="Track" Grid.Column="1"
                                        Width="38" Height="20" CornerRadius="10"
                                        Background="{StaticResource BrushSilverSteel}"
                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Ellipse x:Name="Thumb" Width="16" Height="16"
                                             Fill="{StaticResource BrushPureWhite}"
                                             HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="ThumbShift" X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{StaticResource BrushVividRed}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                                                 Storyboard.TargetProperty="X"
                                                                 To="18" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                                                 Storyboard.TargetProperty="X"
                                                                 To="0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ListBox ── -->
            <Style x:Key="InputListBox" TargetType="ListBox">
                <Setter Property="Background"      Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="4"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"        Value="{StaticResource FontSizeSmall}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <!-- Rounded container (5px radius-md). Default ListBox template
                     draws square corners; re-template with fill / items /
                     stroke-on-top so all four edges are uniform. -->
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBox">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5"/>
                                <ScrollViewer Focusable="False"
                                              Margin="{TemplateBinding BorderThickness}"
                                              Padding="{TemplateBinding Padding}">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                                <Border x:Name="Stroke" CornerRadius="5"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Margin"  Value="1,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowSelected}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ScrollBar ── -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <!-- Vertical -->
                    <Trigger Property="Orientation" Value="Vertical">
                        <Setter Property="Width"    Value="8"/>
                        <Setter Property="MinWidth" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Border Background="{StaticResource BrushOffWhite}" CornerRadius="4" Margin="2,0"/>
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False"
                                                              Opacity="0" Background="Transparent" BorderThickness="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False"
                                                              Opacity="0" Background="Transparent" BorderThickness="0"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="ThumbBd" CornerRadius="3" Margin="2,0"
                                                                    Background="{StaticResource BrushSilverSteel}"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BrushCharcoalBlack}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsDragging" Value="True">
                                                                    <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BrushVividRed}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <!-- Horizontal -->
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Height"    Value="8"/>
                        <Setter Property="MinHeight" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Border Background="{StaticResource BrushOffWhite}" CornerRadius="4" Margin="0,2"/>
                                        <Track x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageLeftCommand" Focusable="False"
                                                              Opacity="0" Background="Transparent" BorderThickness="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageRightCommand" Focusable="False"
                                                              Opacity="0" Background="Transparent" BorderThickness="0"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="ThumbBd" CornerRadius="3" Margin="0,2"
                                                                    Background="{StaticResource BrushSilverSteel}"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BrushCharcoalBlack}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsDragging" Value="True">
                                                                    <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BrushVividRed}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── Section card + badge helper styles ── -->
            <Style x:Key="SectionCard" TargetType="Border">
                <Setter Property="Background"       Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="BorderBrush"      Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="CornerRadius"     Value="8"/>
                <Setter Property="Padding"          Value="16,12"/>
                <Setter Property="Margin"           Value="0,0,0,12"/>
            </Style>
            <Style x:Key="Badge" TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding"      Value="10,3"/>
                <Setter Property="Margin"       Value="0,0,8,0"/>
            </Style>
            <Style x:Key="BadgeText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeCaption}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="{StaticResource BrushOffWhite}">

        <!-- ── Header ── -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BrushCharcoalBlack}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="AnonGee Brand Guidelines" Style="{StaticResource TextH2OnDark}"/>
                <TextBlock Text="Living component gallery — synced with the design system"
                           Style="{StaticResource TextCaption}"
                           Foreground="{StaticResource BrushSilverSteel}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
        <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource BrushVividRed}"/>

        <!-- ── Footer ── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BrushPureWhite}"
                BorderBrush="{StaticResource BrushLightBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <TextBlock Text="Source of truth: AnonGee_BIM_Tools_Brand_Guidelines.md  ·  Theme v3.2"
                           Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                <Button x:Name="BtnClose" Content="Close" HorizontalAlignment="Right"
                        Style="{StaticResource ButtonGhost}" Width="80"/>
            </Grid>
        </Border>

        <!-- ── Scrollable showcase ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,16">
            <StackPanel>

                <!-- Brand Colors -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="BRAND COLORS" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushVividRed}"/>
                                <TextBlock Text="Vivid Red" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#E02020" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushCharcoalBlack}"/>
                                <TextBlock Text="Charcoal" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#141414" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushSilverSteel}"/>
                                <TextBlock Text="Silver Steel" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#C0C8D8" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushOffWhite}"
                                        BorderBrush="{StaticResource BrushLightBorder}" BorderThickness="1"/>
                                <TextBlock Text="Off White" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#F4F4F6" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushMidGrey}"/>
                                <TextBlock Text="Mid Grey" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#6B7280" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushLightBorder}"/>
                                <TextBlock Text="Light Border" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#E2E4EA" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Semantic Colors -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="SEMANTIC / STATE COLORS" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushSuccessGreen}"/>
                                <TextBlock Text="Success" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#16A34A" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushCautionAmber}"/>
                                <TextBlock Text="Caution" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#D97706" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushErrorRed}"/>
                                <TextBlock Text="Error" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#DC2626" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                            <StackPanel Width="96" Margin="0,0,10,8">
                                <Border Height="44" CornerRadius="6" Background="{StaticResource BrushInfoBlue}"/>
                                <TextBlock Text="Info" Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,4,0,0"/>
                                <TextBlock Text="#2563EB" Style="{StaticResource TextSwatchHex}"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock Text="Error Red is distinct from Vivid Red — never substitute one for the other."
                                   Style="{StaticResource TextCaption}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Typography -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="TYPOGRAPHY" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <TextBlock Text="H1 · Window Titles" Style="{StaticResource TextH1}" Margin="0,0,0,4"/>
                        <TextBlock Text="H2 · Section Heading" Style="{StaticResource TextH2}" Margin="0,0,0,4"/>
                        <TextBlock Text="H3 · PANEL / GROUP LABEL" Style="{StaticResource TextH3}" Margin="0,0,0,4"/>
                        <TextBlock Text="Body — prose and form labels render in the primary face."
                                   Style="{StaticResource TextBody}" Margin="0,0,0,4"/>
                        <TextBlock Text="Caption — metadata, footnotes, timestamps" Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="Primary face: JetBrains Mono  →  Source Serif 4  →  Inter  →  Segoe UI  →  Calibri"
                                   Style="{StaticResource TextCaption}" Foreground="{StaticResource BrushCharcoalBlack}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="BUTTONS" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Button Content="Primary"   Style="{StaticResource ButtonPrimary}"   Width="100" Margin="0,0,8,8"/>
                            <Button Content="Secondary" Style="{StaticResource ButtonSecondary}" Width="100" Margin="0,0,8,8"/>
                            <Button Content="Ghost"     Style="{StaticResource ButtonGhost}"     Width="100" Margin="0,0,8,8"/>
                            <Button Content="Danger"    Style="{StaticResource ButtonDanger}"    Width="100" Margin="0,0,8,8"/>
                            <Button Content="Disabled"  Style="{StaticResource ButtonPrimary}"   Width="100" Margin="0,0,8,8" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Inputs -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="TEXT INPUT &amp; COMBOBOX" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <TextBlock Text="Text input" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputTextBox}" Text="Editable sample text" Margin="0,0,0,10"/>
                        <TextBlock Text="ComboBox" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource InputComboBox}" SelectedIndex="0">
                            <ComboBoxItem>First option</ComboBoxItem>
                            <ComboBoxItem>Second option</ComboBoxItem>
                            <ComboBoxItem>Third option</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Selection controls -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="SELECTION CONTROLS" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <TextBlock Text="Checkbox — list selection" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <CheckBox Content="Checked option"   IsChecked="True"  Margin="0,0,0,2"/>
                        <CheckBox Content="Unchecked option" IsChecked="False" Margin="0,0,0,10"/>
                        <TextBlock Text="Radio button — one of a set (§9.4)" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton Content="Option A" GroupName="demo" IsChecked="True" Margin="0,0,16,0"/>
                            <RadioButton Content="Option B" GroupName="demo" Margin="0,0,16,0"/>
                            <RadioButton Content="Option C" GroupName="demo"/>
                        </StackPanel>
                        <TextBlock Text="Toggle switch — binary on/off setting (§9.9)" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <CheckBox Content="Enabled setting"  Style="{StaticResource ToggleSwitch}" IsChecked="True"  Margin="0,0,0,4" Width="220" HorizontalAlignment="Left"/>
                        <CheckBox Content="Disabled setting" Style="{StaticResource ToggleSwitch}" IsChecked="False" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- List -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="LIST" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <ListBox Style="{StaticResource InputListBox}" Height="96" SelectedIndex="1">
                            <ListBoxItem>List item one</ListBoxItem>
                            <ListBoxItem>List item two (selected)</ListBoxItem>
                            <ListBoxItem>List item three</ListBoxItem>
                            <ListBoxItem>List item four</ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Status badges -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="STATUS BADGES" Style="{StaticResource TextH3}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Border Style="{StaticResource Badge}" Background="{StaticResource BrushInfoBadgeBackground}">
                                <TextBlock Text="Ready" Style="{StaticResource BadgeText}" Foreground="{StaticResource BrushInfoBadgeText}"/>
                            </Border>
                            <Border Style="{StaticResource Badge}" Background="{StaticResource BrushSuccessBadgeBackground}">
                                <TextBlock Text="Done — 12 updated" Style="{StaticResource BadgeText}" Foreground="{StaticResource BrushSuccessBadgeText}"/>
                            </Border>
                            <Border Style="{StaticResource Badge}" Background="{StaticResource BrushWarningBadgeBackground}">
                                <TextBlock Text="BETA" Style="{StaticResource BadgeText}" Foreground="{StaticResource BrushWarningBadgeText}"/>
                            </Border>
                            <Border Style="{StaticResource Badge}" Background="{StaticResource BrushErrorBadgeBackground}">
                                <TextBlock Text="Error — invalid input" Style="{StaticResource BadgeText}" Foreground="{StaticResource BrushErrorBadgeText}"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Text="Badges and status text use JetBrains Mono (FontMono)."
                                   Style="{StaticResource TextCaption}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
