<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════
         AnonGee BIM Tools — Panels v3.0
         Window templates, dockable panels, dialogs, group boxes
         ════════════════════════════════════════════════════════════════ -->

    <!-- ════════════════════════════════════════════════════════════════
         STANDARD TOOL WINDOW TEMPLATE
         Charcoal Black header, 3px Vivid Red accent rule, white content, Off White footer.
         ════════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="AnonGeeWindowTemplate" TargetType="Window">
        <DockPanel LastChildFill="True">

            <!-- ── Header ── -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BrushCharcoalBlack}"
                    Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="WindowTitle"
                               Text="{TemplateBinding Title}"
                               Style="{StaticResource TextH2OnDark}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="WindowVersion"
                               Text=""
                               Style="{StaticResource TextCaption}"
                               Foreground="{StaticResource BrushSilverSteel}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Vivid Red accent rule ── -->
            <Rectangle DockPanel.Dock="Top"
                       Height="3"
                       Fill="{StaticResource BrushVividRed}"/>

            <!-- ── Footer / action bar ── -->
            <Border DockPanel.Dock="Bottom"
                    x:Name="FooterBar"
                    Background="{StaticResource BrushOffWhite}"
                    BorderBrush="{StaticResource BrushLightBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="16,10"
                    Height="52">
                <ContentPresenter x:Name="FooterContent" VerticalAlignment="Center"/>
            </Border>

            <!-- ── Scrollable content area ── -->
            <ScrollViewer Padding="20"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter/>
            </ScrollViewer>

        </DockPanel>
    </ControlTemplate>

    <!-- ════════════════════════════════════════════════════════════════
         DIALOG / MODAL WINDOW TEMPLATE
         Fixed-width, CenterOwner, with Cancel (Ghost) + Confirm (Primary) buttons.
         ════════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="AnonGeeDialogTemplate" TargetType="Window">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="3"/>      <!-- Accent rule -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushCharcoalBlack}"
                    Padding="20,14">
                <TextBlock Text="{TemplateBinding Title}"
                           Style="{StaticResource TextH2OnDark}"/>
            </Border>

            <!-- ── Vivid Red accent rule ── -->
            <Rectangle Grid.Row="1"
                       Height="3"
                       Fill="{StaticResource BrushVividRed}"/>

            <!-- ── Scrollable Content ── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,18,20,20">
                <ContentPresenter/>
            </ScrollViewer>

            <!-- ── Bottom action bar with Cancel (Ghost) + Confirm (Primary) ── -->
            <Border Grid.Row="3"
                    Background="{StaticResource BrushOffWhite}"
                    BorderBrush="{StaticResource BrushLightBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource ButtonGhost}"
                            Content="Cancel"
                            Margin="0,0,8,0"
                            IsCancel="True"/>
                    <Button x:Name="ConfirmButton"
                            Style="{StaticResource ButtonPrimary}"
                            Content="Confirm"
                            IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ════════════════════════════════════════════════════════════════
         DOCKABLE PANEL TEMPLATE (Revit IDockablePaneProvider)
         Compact, single-column, MinWidth=240, MaxWidth=360.
         ════════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="DockablePanelTemplate" TargetType="HeaderedContentControl">
        <Border MinWidth="240" MaxWidth="360" Padding="0"
                Background="{StaticResource BrushPureWhite}">
            <DockPanel LastChildFill="True">

                <!-- Compact header -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BrushCharcoalBlack}"
                        Padding="12,10">
                    <TextBlock Text="{TemplateBinding Header}"
                               Style="{StaticResource TextH3OnDark}"/>
                </Border>

                <!-- Accent rule -->
                <Rectangle DockPanel.Dock="Top"
                           Height="2"
                           Fill="{StaticResource BrushVividRed}"/>

                <!-- Content area — single column -->
                <ScrollViewer Padding="12,14"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ContentPresenter/>
                </ScrollViewer>

            </DockPanel>
        </Border>
    </ControlTemplate>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION GROUP BOX (GroupBox style)
         ════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionGroup" TargetType="GroupBox">
        <Setter Property="BorderBrush"     Value="{StaticResource BrushLightBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background"      Value="{StaticResource BrushPureWhite}"/>
        <Setter Property="Padding"         Value="14,12"/>
        <Setter Property="Margin"          Value="0,0,0,16"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel>
                            <!-- Header using H3 style -->
                            <TextBlock Text="{TemplateBinding Header}"
                                       Style="{StaticResource TextH3}"
                                       Margin="2,0,0,8"/>
                            <ContentPresenter/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION DIVIDER
         ════════════════════════════════════════════════════════════════ -->
    <Style x:Key="SectionDivider" TargetType="Rectangle">
        <Setter Property="Height"  Value="1"/>
        <Setter Property="Fill"    Value="{StaticResource BrushLightBorder}"/>
        <Setter Property="Margin"  Value="0,16"/>
    </Style>

</ResourceDictionary>
