                M8 4v0a2 2 0 0 1 2-2h4.586a1 1 0 0 1 .707.293l3.414 3.414a1 1 0 0 1 .293.707V16a2 2 0 0 1-2 2h-1 M14 2v4a1 1 0 0 0 1 1h4 M5 8h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z
            </Geometry>

            <!-- ═══ Controls.xaml ═══ -->
            <Style x:Key="ButtonBaseStyle" TargetType="Button">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="16,0"/>
                <Setter Property="Height"          Value="36"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"        Value="{StaticResource FontSizeBody}"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="BorderBrush"     Value="Transparent"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ButtonPrimary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushVividRed}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushPrimaryForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedPressed}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonSecondary" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushSecondaryBackground}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushSecondaryForeground}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushSecondaryBorder}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushSecondaryHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrushVividRedPressed}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushVividRedPressed}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="BorderBrush" Value="{StaticResource BrushDisabledBackground}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonNeutral" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushNeutralBackground}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushNeutralForeground}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushNeutralBorder}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushLightBorder}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonDanger" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="{StaticResource BrushErrorRed}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushDangerForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushErrorRedHover}"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushVividRedPressed}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ButtonGhost" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushGhostForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BrushGhostHover}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="InputTextBox" TargetType="TextBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"           Value="1"/>
                <Setter Property="Padding"                  Value="10,8"/>
                <Setter Property="Height"                   Value="36"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush"     Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="Validation.HasError" Value="True">
                                    <Setter Property="BorderBrush"     Value="{StaticResource BrushInputErrorBorder}"/>
                                    <Setter Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushDisabledForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputComboBox" TargetType="ComboBox">
                <Setter Property="FontFamily"               Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"                 Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"               Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Background"               Value="{StaticResource BrushInputBackground}"/>
                <Setter Property="BorderBrush"              Value="{StaticResource BrushInputBorder}"/>
                <Setter Property="BorderThickness"           Value="1"/>
                <Setter Property="Padding"                  Value="10,8"/>
                <Setter Property="Height"                   Value="36"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="RootBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <Grid>
                                        <ToggleButton x:Name="ToggleButton" Focusable="False"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid Background="Transparent">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Content="{TemplateBinding Content}"
                                                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                                        <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                              Fill="{StaticResource BrushMidGrey}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    </Grid>
                                </Border>
                                <Popup x:Name="Popup" Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False"
                                       PopupAnimation="Slide"
                                       Width="{TemplateBinding ActualWidth}">
                                    <Border BorderBrush="{StaticResource BrushLightBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Background="{StaticResource BrushPureWhite}"
                                            Effect="{StaticResource ElevationLevel2}">
                                        <ScrollViewer MaxHeight="200" Margin="4">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="RootBorder" Property="BorderBrush"     Value="{StaticResource BrushInputFocusBorder}"/>
                                    <Setter TargetName="RootBorder" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                                    <Setter Property="Foreground"  Value="{StaticResource BrushDisabledForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputCheckBox" TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="MinHeight"  Value="28"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="16" Height="16" CornerRadius="3"
                                        BorderBrush="{StaticResource BrushLightBorder}"
                                        BorderThickness="1"
                                        Background="{StaticResource BrushPureWhite}"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckMark" Data="M0,0 L3,3 L7,-1"
                                          Stroke="{StaticResource BrushPureWhite}"
                                          StrokeThickness="2"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Grid.Column="1" Margin="6,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{StaticResource ColorVividRed}"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BrushVividRed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputRadioButton" TargetType="RadioButton">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"   Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground" Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="Cursor"     Value="Hand"/>
                <Setter Property="MinHeight"  Value="28"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="16" Height="16"
                                         Stroke="{StaticResource BrushLightBorder}"
                                         StrokeThickness="1"
                                         Fill="{StaticResource BrushPureWhite}"
                                         VerticalAlignment="Center"/>
                                <Ellipse x:Name="RadioDot" Grid.Column="0" Width="8" Height="8"
                                         Fill="{StaticResource BrushVividRed}"
                                         Visibility="Collapsed"
                                         VerticalAlignment="Center" HorizontalAlignment="Left"
                                         Margin="4,0,0,0"/>
                                <ContentPresenter Grid.Column="1" Margin="6,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="RadioDot" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="InputListBox" TargetType="ListBox">
                <Setter Property="Background"      Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="4"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"        Value="{StaticResource FontSizeBody}"/>
                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrushInputFocusBorder}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ListBoxItemBase" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushTableRowSelected}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushTableRowSelectedBorder}"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background"    Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="BorderBrush"   Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"  Value="8"/>
                <Setter Property="Padding"       Value="16"/>
            </Style>

            <Style x:Key="CardElevated" TargetType="Border" BasedOn="{StaticResource CardBorder}">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" Opacity="0.10" BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DialogShadow" TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="8" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <DropShadowEffect x:Key="ElevationLevel0" Opacity="0" BlurRadius="0" ShadowDepth="0"/>
            <DropShadowEffect x:Key="ElevationLevel1" Color="#000000" Opacity="0.10" BlurRadius="3" ShadowDepth="1" Direction="270"/>
            <DropShadowEffect x:Key="ElevationLevel2" Color="#000000" Opacity="0.14" BlurRadius="12" ShadowDepth="4" Direction="270"/>
            <DropShadowEffect x:Key="ElevationLevel3" Color="#000000" Opacity="0.18" BlurRadius="24" ShadowDepth="8" Direction="270"/>

            <!-- ═══ Panels.xaml ═══ -->
            <ControlTemplate x:Key="AnonGeeWindowTemplate" TargetType="Window">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BrushCharcoalBlack}"
                            Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       x:Name="WindowTitle" Text="{TemplateBinding Title}"
                                       Style="{StaticResource TextH2OnDark}"/>
                            <TextBlock Grid.Column="1"
                                       WindowVersion=""
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource BrushSilverSteel}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Rectangle DockPanel.Dock="Top"
                               Height="3"
                               Fill="{StaticResource BrushVividRed}"/>
                    <Border DockPanel.Dock="Bottom"
                            x:Name="FooterBar"
                            Background="{StaticResource BrushOffWhite}"
                            BorderBrush="{StaticResource BrushLightBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="16,10"
                            Height="52">
                        <ContentPresenter x:Name="FooterContent" VerticalAlignment="Center"/>
                    </Border>
                    <ScrollViewer Padding="20"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ContentPresenter/>
                    </ScrollViewer>
                </DockPanel>
            </ControlTemplate>

            <ControlTemplate x:Key="AnonGeeDialogTemplate" TargetType="Window">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushCharcoalBlack}"
                            Padding="20,14">
                        <TextBlock Text="{TemplateBinding Title}"
                                   Style="{StaticResource TextH2OnDark}"/>
                    </Border>
                    <Rectangle Grid.Row="1"
                               Height="3"
                               Fill="{StaticResource BrushVividRed}"/>
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,18,20,20">
                        <ContentPresenter/>
                    </ScrollViewer>
                    <Border Grid.Row="3"
                            Background="{StaticResource BrushOffWhite}"
                            BorderBrush="{StaticResource BrushLightBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="20,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="CancelButton"
                                    Style="{StaticResource ButtonGhost}"
                                    Content="Cancel"
                                    Margin="0,0,8,0"
                                    IsCancel="True"/>
                            <Button x:Name="ConfirmButton"
                                    Style="{StaticResource ButtonPrimary}"
                                    Content="Confirm"
                                    IsDefault="True"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ControlTemplate>

            <ControlTemplate x:Key="DockablePanelTemplate" TargetType="HeaderedContentControl">
                <Border MinWidth="240" MaxWidth="360" Padding="0"
                        Background="{StaticResource BrushPureWhite}">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BrushCharcoalBlack}"
                                Padding="12,10">
                            <TextBlock Text="{TemplateBinding Header}"
                                       Style="{StaticResource TextH3OnDark}"/>
                        </Border>
                        <Rectangle DockPanel.Dock="Top"
                                   Height="2"
                                   Fill="{StaticResource BrushVividRed}"/>
                        <ScrollViewer Padding="12,14"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentPresenter/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </ControlTemplate>

            <Style x:Key="SectionGroup" TargetType="GroupBox">
                <Setter Property="BorderBrush"     Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background"      Value="{StaticResource BrushPureWhite}"/>
                <Setter Property="Padding"         Value="14,12"/>
                <Setter Property="Margin"          Value="0,0,0,16"/>
                <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               Style="{StaticResource TextH3}"
                                               Margin="2,0,0,8"/>
                                    <ContentPresenter/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SectionDivider" TargetType="Rectangle">
                <Setter Property="Height"  Value="1"/>
                <Setter Property="Fill"    Value="{StaticResource BrushLightBorder}"/>
                <Setter Property="Margin"  Value="0,16"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BrushCharcoalBlack}" Padding="20,14">
            <TextBlock Text="AnonGee · Structural Framework Generational Operations" Style="{StaticResource TextH2OnDark}"/>
        </Border>

        <!-- Red Accent Rule -->
        <Border DockPanel.Dock="Top" Height="3" Background="{StaticResource BrushVividRed}" />

        <!-- Footer / Action Bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BrushOffWhite}" BorderBrush="{StaticResource BrushLightBorder}" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ButtonCancel" Content="Cancel" Style="{StaticResource ButtonGhost}" Margin="0,0,16,0" IsCancel="True"/>
                <Button x:Name="ButtonGenerate" Content="Generate Structures" Style="{StaticResource ButtonPrimary}" IsDefault="True"/>
            </StackPanel>
        </Border>

        <!-- Main Scrolling Content -->
        <ScrollViewer Padding="20,18,20,20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <GroupBox Header="Data Ingestion Payload" Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <TextBlock Text="Requires standard FRAME outputs format (.inp / .txt)" Style="{StaticResource TextCaption}" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputFilePathBox" Style="{StaticResource InputTextBox}" Margin="0,0,8,0" Grid.Column="0" IsReadOnly="True" />
                            <Button x:Name="ButtonBrowsePath" Content="Browse..." Style="{StaticResource ButtonSecondary}" Grid.Column="1" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Level Sequence Naming Definitions" Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <TextBlock Text="Define output parameters for consecutive level generations" Style="{StaticResource TextCaption}" Margin="0,0,0,8"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Prefix" Style="{StaticResource TextCaption}" Margin="0,0,0,4" />
                                <TextBox x:Name="LevelPrefixInput" Style="{StaticResource InputTextBox}" Text="00" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Base Ordinal" Style="{StaticResource TextCaption}" Margin="0,0,0,4" />
                                <TextBox x:Name="LevelBaseInput" Style="{StaticResource InputTextBox}" Text="0TH" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Suffix" Style="{StaticResource TextCaption}" Margin="0,0,0,4" />
                                <TextBox x:Name="LevelSuffixInput" Style="{StaticResource InputTextBox}" Text="LVL." />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Separator" Style="{StaticResource TextCaption}" Margin="0,0,0,4" />
                                <TextBox x:Name="LevelSeparatorInput" Style="{StaticResource InputTextBox}" Text=" " />
                            </StackPanel>
                        </Grid>
                        
                        <TextBlock x:Name="TextLevelPreview" Text="Preview generation mapping waiting..." Style="{StaticResource TextSmall}" Foreground="{DynamicResource BrushInfoBlue}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Entity Deployment Families" Style="{StaticResource SectionGroup}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Default Context Framing Profile Configurations" Style="{StaticResource TextH4}" Margin="0,0,0,4" />
                            <ComboBox x:Name="ComboStructuralColumns" Style="{StaticResource InputComboBox}" />
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Deployed Target Deployment Component Beam Framing" Style="{StaticResource TextH4}" Margin="0,0,0,4" />
                            <ComboBox x:Name="ComboStructuralBeams" Style="{StaticResource InputComboBox}" />
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Concrete Layer Foundation Slabs Targeting Configuration" Style="{StaticResource TextH4}" Margin="0,0,0,4" />
                            <ComboBox x:Name="ComboFloorTypes" Style="{StaticResource InputComboBox}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
                
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>