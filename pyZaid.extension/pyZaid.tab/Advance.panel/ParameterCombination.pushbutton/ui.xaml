<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parameter Combination - Advanced" Height="700" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#F5F5F5" FontFamily="Segoe UI" UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- THEME COLOR PALETTE -->
        <Color x:Key="AccentColor">#3498DB</Color>
        <Color x:Key="SuccessColor">#27AE60</Color>
        <Color x:Key="DangerColor">#E74C3C</Color>
        <Color x:Key="LightBgColor">#F5F5F5</Color>
        <Color x:Key="DarkTextColor">#2C3E50</Color>
        <Color x:Key="GrayTextColor">#7F8C8D</Color>
        <Color x:Key="WhiteColor">#FFFFFF</Color>
        <Color x:Key="BorderColor">#BDC3C7</Color>
        <Color x:Key="DividerColor">#D5D8DC</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="DarkTextBrush" Color="{StaticResource DarkTextColor}" />
        <SolidColorBrush x:Key="GrayTextBrush" Color="{StaticResource GrayTextColor}" />
        <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}" />
        <SolidColorBrush x:Key="LightBgBrush" Color="{StaticResource LightBgColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
        <SolidColorBrush x:Key="SoftHighlight" Color="#EBF5FB" />

        <!-- SHARED STYLES -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Control" x:Key="InputStyle">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
        </Style>

        <!-- Fixed Padding Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Fixed Padding Secondary Button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                    <Setter Property="Foreground" Value="#2980B9"/>
                    <Setter Property="BorderBrush" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Animated Toggle Switch -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SwitchPill" Width="36" Height="20" CornerRadius="10" Background="{StaticResource BorderBrush}" VerticalAlignment="Center">
                                <Ellipse x:Name="SwitchThumb" Width="14" Height="14" Fill="White" Margin="3,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchPill" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Tab RadioButton Style -->
        <Style x:Key="TabRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border BorderThickness="0,0,0,2" BorderBrush="Transparent" x:Name="Bd" Padding="0,0,0,4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PREMIUM DATAGRID STYLES (Fixed Vertical Alignment) -->
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
        </Style>

        <Style x:Key="SafeRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SoftHighlight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SafeCellStyle" TargetType="DataGridCell">
            <!-- Removed VerticalAlignment="Center" so the cell perfectly fills the row height! -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SoftHighlight}"/>
                    <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
        
        <Style x:Key="NormalTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <!-- MAIN LAYOUT -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   
            <RowDefinition Height="*"/>      
            <RowDefinition Height="Auto"/>   
        </Grid.RowDefinitions>

        <!-- TOP HEADER BAR -->
        <Border Grid.Row="0" Background="{StaticResource DarkTextBrush}" Padding="15,10" Margin="15,15,15,10" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Parameter Combination - Advanced" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Batch Processor" FontSize="12" Foreground="{StaticResource BorderBrush}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- BODY SECTION -->
        <Grid Grid.Row="1" Margin="15,0,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Idea #4 Implementation: Text Case -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1. Target Parameter" Style="{StaticResource HeaderStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="Output Text Case" Style="{StaticResource SubHeaderStyle}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="TargetParamCombo" Height="30" Margin="0,0,10,0" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Style="{StaticResource InputStyle}"/>
                        <ComboBox Grid.Column="1" x:Name="TextCaseCombo" Height="30" Style="{StaticResource InputStyle}">
                            <ComboBoxItem Content="Keep Original" IsSelected="True"/>
                            <ComboBoxItem Content="UPPERCASE"/>
                            <ComboBoxItem Content="lowercase"/>
                            <ComboBoxItem Content="Title Case"/>
                        </ComboBox>
                    </Grid>

                    <!-- OPERATION TABS -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton x:Name="ModeFormula" Content="Formula" IsChecked="True" Style="{StaticResource TabRadioStyle}"/>
                        <RadioButton x:Name="ModeReplace" Content="Find &amp; Replace" Style="{StaticResource TabRadioStyle}"/>
                        <RadioButton x:Name="ModeAffix" Content="Prefix / Suffix" Style="{StaticResource TabRadioStyle}"/>
                        <RadioButton x:Name="ModeSeq" Content="Sequence" Style="{StaticResource TabRadioStyle}"/>
                    </StackPanel>

                    <!-- TAB CONTENTS CONTAINER -->
                    <Grid Grid.Row="3">
                        
                        <!-- TAB 1: FORMULA -->
                        <Grid x:Name="GridFormula">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <CheckBox Grid.Row="0" x:Name="ToggleMath" Content="Evaluate Math Formulas" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"/>
                            
                            <Grid Grid.Row="1" Margin="0,0,0,15">
                                <RichTextBox x:Name="FormulaRichTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Style="{StaticResource InputStyle}" Padding="6">
                                    <FlowDocument>
                                        <Paragraph Margin="0"/>
                                    </FlowDocument>
                                </RichTextBox>
                                <Popup x:Name="SuggestPopup" PlacementTarget="{Binding ElementName=FormulaRichTextBox}" Placement="Bottom" StaysOpen="False" MaxHeight="180" Width="280">
                                    <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5" CornerRadius="4">
                                        <ListBox x:Name="SuggestListBox" Background="White" Foreground="{StaticResource DarkTextBrush}" BorderThickness="0"/>
                                    </Border>
                                </Popup>
                            </Grid>
                            
                            <Grid Grid.Row="2" VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" x:Name="SourceParamCombo" Margin="0,0,10,0" Height="30" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Style="{StaticResource InputStyle}"/>
                                <Button Grid.Column="1" x:Name="InsertParamBtn" Content="Insert" Width="80" Height="30" Background="#E8E8E8" Foreground="{StaticResource DarkTextBrush}" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>

                        <!-- TAB 2: FIND & REPLACE -->
                        <Grid x:Name="GridReplace" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Find what:" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="1" x:Name="FindTextBox" Height="30" Margin="0,0,0,15" Style="{StaticResource InputStyle}"/>
                            <TextBlock Grid.Row="2" Text="Replace with:" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="3" x:Name="ReplaceTextBox" Height="30" Style="{StaticResource InputStyle}"/>
                        </Grid>

                        <!-- TAB 3: PREFIX / SUFFIX -->
                        <Grid x:Name="GridAffix" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Add Prefix:" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="1" x:Name="PrefixTextBox" Height="30" Margin="0,0,0,15" Style="{StaticResource InputStyle}"/>
                            <TextBlock Grid.Row="2" Text="Add Suffix:" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="3" x:Name="SuffixTextBox" Height="30" Style="{StaticResource InputStyle}"/>
                        </Grid>

                        <!-- TAB 4: SEQUENCE -->
                        <Grid x:Name="GridSeq" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Start Value (e.g., Door-01):" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="1" x:Name="SeqStartTextBox" Height="30" Margin="0,0,0,15" Style="{StaticResource InputStyle}"/>
                            <TextBlock Grid.Row="2" Text="Numeric Step Increment:" Style="{StaticResource SubHeaderStyle}"/>
                            <TextBox Grid.Row="3" x:Name="SeqStepTextBox" Text="1" Height="30" Style="{StaticResource InputStyle}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- RIGHT PANEL: Real-time DataGrid Card -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="3. Real-Time Result Preview" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center" Margin="0"/>
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,0">
                            <Button x:Name="BtnSelectAll" Content="Select All" Background="Transparent" Foreground="{StaticResource AccentBrush}" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button x:Name="BtnSelectNone" Content="Select None" Background="Transparent" Foreground="{StaticResource GrayTextBrush}" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                        </StackPanel>
                        
                        <TextBox Grid.Column="3" x:Name="FilterGridTextBox" Width="180" Height="28" Style="{StaticResource InputStyle}" Text="Filter results..." Foreground="{StaticResource GrayTextBrush}"/>
                    </Grid>
                    
                    <!-- PREMIUM DATAGRID (Fixed formatting & Checkboxes) -->
                    <DataGrid Grid.Row="1" x:Name="ElementGrid"
                              Background="{StaticResource WhiteBrush}"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                              AlternatingRowBackground="{StaticResource LightBgBrush}"
                              RowBackground="{StaticResource WhiteBrush}"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="{StaticResource DividerBrush}"
                              HorizontalGridLinesBrush="{StaticResource DividerBrush}"
                              RowHeight="32" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              RowStyle="{StaticResource SafeRowStyle}"
                              CellStyle="{StaticResource SafeCellStyle}">
                        
                        <DataGrid.Columns>
                            <!-- ONE-CLICK TEMPLATE CHECKBOX! -->
                            <DataGridTemplateColumn Header="✓" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Apply, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" IsReadOnly="True" Width="80" ElementStyle="{StaticResource NormalTextStyle}"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding Family}" IsReadOnly="True" Width="140" ElementStyle="{StaticResource NormalTextStyle}"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="140" ElementStyle="{StaticResource NormalTextStyle}"/> 
                            
                            <DataGridTextColumn Header="Preview Result (To Be Applied)" Binding="{Binding Preview}" IsReadOnly="True" Width="*" ElementStyle="{StaticResource PreviewTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM FOOTER -->
        <Border Grid.Row="2" Background="#E8E8E8" Padding="15,10" Margin="15,0,15,15" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="StatusBar" Text="Ready" Foreground="{StaticResource GrayTextBrush}" 
                           FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                           
                <Button Grid.Column="1" x:Name="ApplyBtn" Content="Apply Changes to Checked Elements" Width="260" Margin="0,0,15,0" Style="{StaticResource PrimaryBtn}"/>
                <Button Grid.Column="2" x:Name="CancelBtn" Content="Cancel" Width="100" Style="{StaticResource SecondaryBtn}"/>
            </Grid>
        </Border>
    </Grid>
</Window>