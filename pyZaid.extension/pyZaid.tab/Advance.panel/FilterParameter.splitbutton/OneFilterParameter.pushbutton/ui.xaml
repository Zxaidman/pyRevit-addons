        <!-- ═══════════════════════════════════════════════════════════════
             TOOL-SPECIFIC STYLES
             ═══════════════════════════════════════════════════════════════ -->

        <Style x:Key="SectionLabel" TargetType="Label">
            <Setter Property="FontFamily"      Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeH3}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushVividRed}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding"         Value="0,0,0,4"/>
            <Setter Property="Margin"          Value="0,3,0,3"/>
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize"     Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground"   Value="{StaticResource BrushMidGrey}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,4,0,0"/>
        </Style>

        <Style x:Key="DividerRule" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill"   Value="{StaticResource BrushLightBorder}"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize"          Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushCharcoalBlack}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableHeaderText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
            <Setter Property="FontSize"   Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPureWhite}"/>
            <Setter Property="Padding"    Value="8,6"/>
        </Style>

        <Style x:Key="TableCellText" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize"          Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushCharcoalBlack}"/>
            <Setter Property="Padding"           Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCellTextMono" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize"          Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushMidGrey}"/>
            <Setter Property="Padding"           Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="MinWidth"            Value="16"/>
            <Setter Property="MinHeight"           Value="16"/>
        </Style>

        <!-- CategoryListItem now uses BasedOn since ListBoxItemBase is defined inline above -->
        <Style x:Key="CategoryListItem" TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemBase}">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin"  Value="1"/>
        </Style>

        <!-- ── Custom ScrollBar — 8px, rounded, brand-matched (implicit — applies to all ScrollBars) ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="MinWidth"   Value="8"/>
            <!-- Vertical template (default) -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="{StaticResource BrushOffWhite}"
                                    CornerRadius="4" Margin="2,0"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBd"
                                                        CornerRadius="3" Margin="2,0"
                                                        Background="{StaticResource BrushSilverSteel}"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Background"
                                                                Value="{StaticResource BrushCharcoalBlack}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBd" Property="Background"
                                                                Value="{StaticResource BrushVividRed}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Horizontal orientation override -->
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width"     Value="Auto"/>
                    <Setter Property="MinWidth"  Value="0"/>
                    <Setter Property="Height"    Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Border Background="{StaticResource BrushOffWhite}"
                                            CornerRadius="4" Margin="0,2"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                          Focusable="False" Opacity="0"
                                                          Background="Transparent" BorderThickness="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand"
                                                          Focusable="False" Opacity="0"
                                                          Background="Transparent" BorderThickness="0"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBd"
                                                                CornerRadius="3" Margin="0,2"
                                                                Background="{StaticResource BrushSilverSteel}"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBd" Property="Background"
                                                                        Value="{StaticResource BrushCharcoalBlack}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBd" Property="Background"
                                                                        Value="{StaticResource BrushVividRed}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0 : Header (Charcoal Black) -->
            <RowDefinition Height="3"/>     <!-- 1 : Vivid Red accent rule -->
            <RowDefinition Height="*"/>     <!-- 2 : Body (left panel + table) -->
            <RowDefinition Height="Auto"/>  <!-- 3 : Status bar -->
            <RowDefinition Height="Auto"/>  <!-- 4 : Action bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushCharcoalBlack}"
                Padding="16,10"
                CornerRadius="5,5,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="header_title"
                           Text="AnonGee · Filter Parameter"
                           FontSize="{StaticResource FontSizeH2}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushPureWhite}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="live_count"
                           Text="0 Elements"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource BrushSilverSteel}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Vivid Red accent rule ── -->
        <Rectangle Grid.Row="1" Fill="{StaticResource BrushVividRed}"/>

        <!-- ── Body ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="340" MaxWidth="380"/>
                <ColumnDefinition Width="Auto" MaxWidth="10"/>
                <ColumnDefinition Width="*"    MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,8,0">

                    <Label Content="Scope:" Style="{StaticResource SectionLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="rb_whole"     Content="Whole Model" GroupName="scope" IsChecked="True" Margin="0,0,12,0" Style="{StaticResource InputRadioButton}"/>
                        <RadioButton x:Name="rb_view"      Content="Active View"  GroupName="scope" Margin="0,0,12,0"                  Style="{StaticResource InputRadioButton}"/>
                        <RadioButton x:Name="rb_selection" Content="Selection"    GroupName="scope"                                     Style="{StaticResource InputRadioButton}"/>
                    </StackPanel>

                    <Label Content="Categories:" Style="{StaticResource SectionLabel}"/>
                    <ListBox x:Name="category_list"
                             Style="{StaticResource InputListBox}"
                             ItemContainerStyle="{StaticResource CategoryListItem}"
                             Height="80" Margin="0,0,0,8" Padding="2"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="btn_all_cats"  Content="All"  Style="{StaticResource ButtonGhost}" Width="50"              ToolTip="Select all"/>
                            <Button x:Name="btn_none_cats" Content="None" Style="{StaticResource ButtonGhost}" Width="55" Margin="4,0,0,0" ToolTip="Clear all"/>
                        </StackPanel>
                        <Button Grid.Column="2" x:Name="btn_load_params" Content="Load Parameters"
                                Style="{StaticResource ButtonPrimary}" Width="150" ToolTip="Load parameters"/>
                    </Grid>
                    <TextBlock x:Name="cat_status" Text="Select scope and categories, then click Load Parameters."
                               Style="{StaticResource StatusText}"/>

                    <Rectangle Style="{StaticResource DividerRule}"/>

                    <Label Content="Filter by Parameter:" Style="{StaticResource SectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Parameter:" Style="{StaticResource FieldLabel}" Margin="0,0,4,4"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="filter_param" Style="{StaticResource InputComboBox}" IsEditable="True" Margin="0,0,4,4"/>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="btn_confirm_param" Content="&#x2713;" Style="{StaticResource ButtonGhost}" FontSize="{StaticResource FontSizeH4}" Padding="0" Margin="0,0,0,4" ToolTip="Load operators"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Operator:" Style="{StaticResource FieldLabel}" Margin="0,0,4,4"/>
                        <ComboBox  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="filter_op" Style="{StaticResource InputComboBox}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Value:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="filter_val" Style="{StaticResource InputComboBox}" IsEditable="True"/>
                    </Grid>
                    <TextBlock x:Name="filter_status" Text="Choose parameter, operator, and value."
                               Style="{StaticResource StatusText}" Margin="0,0,0,4"/>
                    <Button x:Name="btn_apply_filter" Content="Apply Filter"
                            Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Right"
                            Width="130" Margin="0,4,0,0"
                            ToolTip="Filter elements by the selected parameter and value"/>

                    <Rectangle Style="{StaticResource DividerRule}"/>

                    <Label Content="Edit Parameters:" Style="{StaticResource SectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Parameter:" Style="{StaticResource FieldLabel}" Margin="0,0,4,4"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="edit_param" Style="{StaticResource InputComboBox}" IsEditable="True" Margin="0,0,4,4"/>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="btn_confirm_edit" Content="&#x2713;" Style="{StaticResource ButtonGhost}" FontSize="{StaticResource FontSizeH4}" Padding="0" Margin="0,0,0,4" ToolTip="Confirm edit parameter"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Operation:" Style="{StaticResource FieldLabel}" Margin="0,0,4,4"/>
                        <ComboBox  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="edit_op" Style="{StaticResource InputComboBox}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Value:"   Style="{StaticResource FieldLabel}" Margin="0,0,4,4"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="edit_val1" Style="{StaticResource InputComboBox}" IsEditable="True" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Replace:" Style="{StaticResource FieldLabel}" Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="edit_val2" Style="{StaticResource InputTextBox}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                        <Button x:Name="btn_execute" Content="Execute"
                                Style="{StaticResource ButtonPrimary}" Width="100"
                                ToolTip="Execute edit on filtered elements"/>
                    </StackPanel>
                    <TextBlock x:Name="edit_status" Text="Apply filter first, then edit."
                               Style="{StaticResource StatusText}"/>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource BrushLightBorder}" ResizeBehavior="BasedOnAlignment"/>

            <!-- Right panel: live preview table -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" VerticalAlignment="Stretch" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DataGrid — headers + rows + scrolling all built-in -->
                    <DataGrid Grid.Row="0" x:Name="preview_list"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"     CanUserDeleteRows="False"
                              CanUserReorderColumns="False" CanUserSortColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BrushLightBorder}"
                              Background="{StaticResource BrushPureWhite}"
                              RowBackground="{StaticResource BrushPureWhite}"
                              AlternatingRowBackground="{StaticResource BrushOffWhite}"
                              BorderThickness="0"
                              RowHeight="28"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              FontFamily="{StaticResource FontSans}"
                              FontSize="{StaticResource FontSizeCaption}">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"              Value="{StaticResource BrushCharcoalBlack}"/>
                                <Setter Property="Foreground"              Value="{StaticResource BrushPureWhite}"/>
                                <Setter Property="FontFamily"              Value="{StaticResource FontSans}"/>
                                <Setter Property="FontSize"                Value="{StaticResource FontSizeCaption}"/>
                                <Setter Property="FontWeight"              Value="SemiBold"/>
                                <Setter Property="Padding"                 Value="8,6"/>
                                <Setter Property="BorderBrush"             Value="{StaticResource BrushMidGrey}"/>
                                <Setter Property="BorderThickness"         Value="0,0,1,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Resources>
                            <!-- Override system selection colors so row text stays dark on brand bg -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#FECACA"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#141414"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#FECACA"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#141414"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BrushTableRowHover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FECACA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"      Value="{StaticResource BrushCharcoalBlack}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background"  Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground"  Value="{StaticResource BrushCharcoalBlack}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <!-- ✓ column — Border+Path with DataTrigger; avoids Nullable<bool> binding issues -->
                            <DataGridTemplateColumn Header="" Width="36" CanUserSort="False" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="16" Height="16" CornerRadius="3"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"  Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#E2E4EA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"  Value="#E02020"/>
                                                            <Setter Property="BorderBrush" Value="#E02020"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Path Data="M2,7 L5,10 L11,3"
                                                  Stroke="White" StrokeThickness="1.5"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Element ID"   Binding="{Binding ElementId}"   Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily"        Value="{StaticResource FontMono}"/>
                                        <Setter Property="Foreground"        Value="{StaticResource BrushMidGrey}"/>
                                        <Setter Property="Padding"           Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Family Name"  Binding="{Binding FamilyName}"  Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding"           Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Type Name"    Binding="{Binding TypeName}"    Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding"           Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Filter Param" Binding="{Binding FilterValue}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="{StaticResource BrushVividRed}"/>
                                        <Setter Property="Padding"           Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Edit Preview" Binding="{Binding EditPreview}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding"           Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Table footer -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushOffWhite}"
                            BorderBrush="{StaticResource BrushLightBorder}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,7,7"
                            Padding="8,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="preview_info"
                                       Text="0 elements loaded"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource BrushMidGrey}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button x:Name="btn_select_all_rows"   Content="Select All"
                                        Style="{StaticResource ButtonGhost}" Height="24"
                                        FontSize="{StaticResource FontSizeCaption}" Padding="8,0"/>
                                <Button x:Name="btn_deselect_all_rows" Content="Clear"
                                        Style="{StaticResource ButtonGhost}" Height="24"
                                        FontSize="{StaticResource FontSizeCaption}" Padding="8,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="3"
                Background="{StaticResource BrushOffWhite}"
                BorderBrush="{StaticResource BrushLightBorder}"
                BorderThickness="1"
                Padding="12,8" Margin="0,8,0,0" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="status_badge"
                        Background="{StaticResource BrushSuccessBadgeBackground}"
                        BorderBrush="{StaticResource BrushSuccessGreen}"
                        BorderThickness="1" CornerRadius="3" Padding="10,2">
                    <TextBlock x:Name="status_textblock" Text="Ready"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource BrushSuccessBadgeText}"
                               FontWeight="SemiBold"/>
                </Border>
                <Border x:Name="error_badge"
                        Background="{StaticResource BrushErrorBadgeBackground}"
                        BorderBrush="{StaticResource BrushErrorRed}"
                        BorderThickness="1" CornerRadius="3" Padding="10,2"
                        Visibility="Collapsed">
                    <TextBlock x:Name="error_text" Text="Error"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource BrushErrorBadgeText}"
                               FontWeight="SemiBold"/>
                </Border>
                <TextBlock Grid.Column="2"
                           Text="AnonGee · Filter Parameter v3.0"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource BrushMidGrey}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Action bar ── -->
        <Border Grid.Row="4"
                Background="{StaticResource BrushOffWhite}"
                BorderBrush="{StaticResource BrushLightBorder}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btn_select_elems"
                        Content="Select in Revit"
                        Style="{StaticResource ButtonSecondary}" Width="140"
                        HorizontalAlignment="Right"
                        ToolTip="Select filtered elements in Revit"
                        IsEnabled="False"/>
                <Button Grid.Column="1" x:Name="btn_close"
                        Content="Close"
                        Style="{StaticResource ButtonGhost}" Width="100"
                        HorizontalAlignment="Right"
                        ToolTip="Close without selecting"
                        Margin="10,0,0,0"/>
            </Grid>
        </Border>

    </Grid>
</Window>
