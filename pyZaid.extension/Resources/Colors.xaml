<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════
         AnonGee BIM Tools — Colors v3.0
         Brand: Vivid Red (#E02020), Charcoal Black (#141414), Silver Steel (#C0C8D8)
         ════════════════════════════════════════════════════════════════ -->

    <!-- ═══ Brand Colors ═══ -->
    <Color x:Key="ColorVividRed">#FFE02020</Color>
    <Color x:Key="ColorCharcoalBlack">#FF141414</Color>
    <Color x:Key="ColorSilverSteel">#FFC0C8D8</Color>

    <!-- ═══ Surface & Text Colors ═══ -->
    <Color x:Key="ColorPureWhite">#FFFFFFFF</Color>
    <Color x:Key="ColorOffWhite">#FFF4F4F6</Color>
    <Color x:Key="ColorMidGrey">#FF6B7280</Color>
    <Color x:Key="ColorLightBorder">#FFE2E4EA</Color>

    <!-- ═══ Semantic / State Colors ═══ -->
    <Color x:Key="ColorSuccessGreen">#FF16A34A</Color>
    <Color x:Key="ColorCautionAmber">#FFD97706</Color>
    <Color x:Key="ColorErrorRed">#FFDC2626</Color>
    <Color x:Key="ColorInfoBlue">#FF2563EB</Color>

    <!-- ═══ Hover & Pressed Variants ═══ -->
    <!-- Vivid Red hover/pressed -->
    <Color x:Key="ColorVividRedHover">#FFC41A1A</Color>
    <Color x:Key="ColorVividRedPressed">#FFA81515</Color>

    <!-- Error Red hover -->
    <Color x:Key="ColorErrorRedHover">#FFB91C1C</Color>

    <!-- Secondary (VividRed outline) hover background — very light red tint -->
    <Color x:Key="ColorVividRed10">#1AE02020</Color>

    <!-- Ghost hover background -->
    <Color x:Key="ColorOffWhiteHover">#FFE8E8EC</Color>

    <!-- ═══ SolidColorBrush Resources ═══ -->

    <!-- Brand brushes -->
    <SolidColorBrush x:Key="BrushVividRed"      Color="{StaticResource ColorVividRed}"/>
    <SolidColorBrush x:Key="BrushCharcoalBlack" Color="{StaticResource ColorCharcoalBlack}"/>
    <SolidColorBrush x:Key="BrushSilverSteel"   Color="{StaticResource ColorSilverSteel}"/>

    <!-- Surface & text brushes -->
    <SolidColorBrush x:Key="BrushPureWhite"     Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushOffWhite"      Color="{StaticResource ColorOffWhite}"/>
    <SolidColorBrush x:Key="BrushMidGrey"       Color="{StaticResource ColorMidGrey}"/>
    <SolidColorBrush x:Key="BrushLightBorder"   Color="{StaticResource ColorLightBorder}"/>

    <!-- Semantic brushes -->
    <SolidColorBrush x:Key="BrushSuccessGreen"  Color="{StaticResource ColorSuccessGreen}"/>
    <SolidColorBrush x:Key="BrushCautionAmber"  Color="{StaticResource ColorCautionAmber}"/>
    <SolidColorBrush x:Key="BrushErrorRed"      Color="{StaticResource ColorErrorRed}"/>
    <SolidColorBrush x:Key="BrushInfoBlue"      Color="{StaticResource ColorInfoBlue}"/>

    <!-- Hover & pressed brushes -->
    <SolidColorBrush x:Key="BrushVividRedHover"    Color="{StaticResource ColorVividRedHover}"/>
    <SolidColorBrush x:Key="BrushVividRedPressed"  Color="{StaticResource ColorVividRedPressed}"/>
    <SolidColorBrush x:Key="BrushErrorRedHover"    Color="{StaticResource ColorErrorRedHover}"/>
    <SolidColorBrush x:Key="BrushSecondaryHover"   Color="{StaticResource ColorVividRed10}"/>
    <SolidColorBrush x:Key="BrushGhostHover"       Color="{StaticResource ColorOffWhiteHover}"/>

    <!-- Disabled state brushes -->
    <SolidColorBrush x:Key="BrushDisabledBackground"  Color="{StaticResource ColorLightBorder}"/>
    <SolidColorBrush x:Key="BrushDisabledForeground"  Color="{StaticResource ColorSilverSteel}"/>

    <!-- Button-specific state brushes -->
    <SolidColorBrush x:Key="BrushPrimaryForeground"   Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushSecondaryBackground" Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushSecondaryBorder"     Color="{StaticResource ColorVividRed}"/>
    <SolidColorBrush x:Key="BrushSecondaryForeground" Color="{StaticResource ColorVividRed}"/>
    <SolidColorBrush x:Key="BrushNeutralBackground"   Color="{StaticResource ColorOffWhite}"/>
    <SolidColorBrush x:Key="BrushNeutralForeground"   Color="{StaticResource ColorCharcoalBlack}"/>
    <SolidColorBrush x:Key="BrushNeutralBorder"       Color="{StaticResource ColorLightBorder}"/>
    <SolidColorBrush x:Key="BrushDangerForeground"    Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushGhostForeground"     Color="{StaticResource ColorMidGrey}"/>

    <!-- Input-specific brushes -->
    <SolidColorBrush x:Key="BrushInputBackground"    Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushInputBorder"        Color="{StaticResource ColorLightBorder}"/>
    <SolidColorBrush x:Key="BrushInputFocusBorder"   Color="{StaticResource ColorVividRed}"/>
    <SolidColorBrush x:Key="BrushInputErrorBorder"   Color="{StaticResource ColorErrorRed}"/>

    <!-- Status badge brushes -->
    <SolidColorBrush x:Key="BrushSuccessBadgeBackground" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="BrushSuccessBadgeText"      Color="#15803D"/>
    <SolidColorBrush x:Key="BrushWarningBadgeBackground" Color="#FEF9C3"/>
    <SolidColorBrush x:Key="BrushWarningBadgeText"      Color="#92400E"/>
    <SolidColorBrush x:Key="BrushErrorBadgeBackground"  Color="#FEE2E2"/>
    <SolidColorBrush x:Key="BrushErrorBadgeText"        Color="#991B1B"/>
    <SolidColorBrush x:Key="BrushInfoBadgeBackground"   Color="#DBEAFE"/>
    <SolidColorBrush x:Key="BrushInfoBadgeText"         Color="#1D4ED8"/>
    <SolidColorBrush x:Key="BrushBetaBadgeBackground"   Color="{StaticResource ColorCharcoalBlack}"/>
    <SolidColorBrush x:Key="BrushBetaBadgeText"         Color="{StaticResource ColorSilverSteel}"/>
    <SolidColorBrush x:Key="BrushActiveBadgeBackground" Color="{StaticResource ColorVividRed}"/>
    <SolidColorBrush x:Key="BrushActiveBadgeText"       Color="{StaticResource ColorPureWhite}"/>

    <!-- Data table brushes -->
    <SolidColorBrush x:Key="BrushTableHeaderBackground" Color="{StaticResource ColorCharcoalBlack}"/>
    <SolidColorBrush x:Key="BrushTableHeaderText"       Color="{StaticResource ColorPureWhite}"/>
    <SolidColorBrush x:Key="BrushTableRowHover"         Color="#FDECEA"/>
    <SolidColorBrush x:Key="BrushTableRowSelected"      Color="#FEF2F2"/>
    <SolidColorBrush x:Key="BrushTableRowSelectedBorder" Color="{StaticResource ColorVividRed}"/>

</ResourceDictionary>