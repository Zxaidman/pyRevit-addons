<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== MAIN TOOL WINDOW TEMPLATE ==================== -->
    <!-- Usage: Window template with dark header, accent bar, scrollable content, and optional footer. -->
    <ControlTemplate x:Key="AnonGeeWindowTemplate" TargetType="Window">
        <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Background="{StaticResource BrushBackgroundDark}" Padding="16,12">
                <TextBlock Text="{TemplateBinding Title}" Style="{StaticResource TextH2}"
                           Foreground="{StaticResource BrushBackgroundLight}"/>
            </Border>

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="3" Fill="{StaticResource BrushAccentBlue}"/>

            <!-- Scrollable content area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ContentPresenter/>
            </ScrollViewer>

            <!-- Optional bottom action bar (can be populated via code if needed) -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource BrushNeutral100}"
                    Padding="12" Height="52">
                <ContentPresenter x:Name="FooterContent" VerticalAlignment="Center"/>
            </Border>
        </DockPanel>
    </ControlTemplate>

    <!-- ==================== DIALOG TEMPLATE ==================== -->
    <!-- Pre-built with Cancel (Ghost) and Confirm (Primary) buttons. Commands must be wired in code. -->
    <ControlTemplate x:Key="AnonGeeDialogTemplate" TargetType="Window">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="3"/>      <!-- Accent bar -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrushBackgroundDark}" Padding="16,12">
                <TextBlock Text="{TemplateBinding Title}" Style="{StaticResource TextH2}"
                           Foreground="{StaticResource BrushBackgroundLight}"/>
            </Border>

            <!-- Accent bar -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushAccentBlue}"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ContentPresenter Margin="24"/>
            </ScrollViewer>

            <!-- Bottom buttons -->
            <Border Grid.Row="3" Background="{StaticResource BrushNeutral100}" Padding="12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Style="{StaticResource ButtonGhost}"
                            Content="Cancel" Margin="0,0,8,0"/>
                    <Button x:Name="ConfirmButton" Style="{StaticResource ButtonPrimary}"
                            Content="Confirm"/>
                </StackPanel>
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ==================== DOCKABLE PANEL TEMPLATE ==================== -->
    <!-- Compact panel with header and single-column content. MinWidth=240. -->
    <ControlTemplate x:Key="DockablePanelTemplate" TargetType="HeaderedContentControl">
        <Border MinWidth="240" Padding="0" Background="White">
            <StackPanel>
                <!-- Compact header -->
                <Border Padding="12,8" Background="{StaticResource BrushNeutral100}">
                    <TextBlock Text="{TemplateBinding Header}" Style="{StaticResource TextH3}"/>
                </Border>
                <!-- Content area: single-column StackPanel -->
                <ContentPresenter Margin="12"/>
            </StackPanel>
        </Border>
    </ControlTemplate>

    <!-- ==================== SECTION GROUP BOX (GroupBox style) ==================== -->
    <Style x:Key="SectionGroup" TargetType="GroupBox">
        <Setter Property="BorderBrush" Value="{StaticResource BrushNeutral200}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel>
                            <!-- Header using H3 style -->
                            <TextBlock Text="{TemplateBinding Header}" Style="{StaticResource TextH3}"
                                       Margin="0,0,0,8"/>
                            <ContentPresenter/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>